{
  "name": "@tokenring-ai/ghost-io",
  "version": "0.2.0",
  "description": "Ghost.io integration for Token Ring",
  "dependencies": {
    "@tokenring-ai/app": "0.2.0",
    "zod": "^4.3.6",
    "@tokenring-ai/blog": "0.2.0",
    "@tokenring-ai/cdn": "0.2.0",
    "@tokenring-ai/utility": "0.2.0",
    "@tryghost/admin-api": "^1.14.7",
    "form-data": "^4.0.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "vitest": "^4.1.1",
